# Upstream MCP server URL (required in production)
UPSTREAM_MCP_URL=http://localhost:9000

# Anthropic API key (required when semantic_judge=anthropic in aegis-config.yaml)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# HITL webhook for escalation notifications (optional)
HITL_WEBHOOK_URL=https://hooks.example.com/your-webhook

# Base URL for review links in webhook payloads (optional, defaults to http://localhost:8000)
HITL_REVIEW_BASE_URL=http://localhost:8000

# Next.js console — API base URL (required in production console deploy)
NEXT_PUBLIC_API_URL=http://localhost:8000
